# Backend
backend/target/
backend/*.iml
backend/.mvn/wrapper/maven-wrapper.jar
backend/music-data/  # 建议忽略本地测试的 SQLite 数据库和上传的文件
backend/application-secret.yml

# Frontend
frontend/node_modules/
frontend/.nuxt/
frontend/.output/
frontend/dist/
frontend/.env

# Music data (don't commit large media files)
backend/music-data/audio/*.mp3
backend/music-data/covers/*.jpg
backend/music-data/covers/*.png
backend/music-data/covers/*.webp

# IDE
.idea/
*.iml
.vscode/

# OS
.DS_Store
Thumbs.db


# ==========================================
# 🎵 核心屏蔽：大文件与多媒体资源 (绝对不能传)
# ==========================================
# 屏蔽你存放音乐和数据库的本地目录
music-data/
*.db
*.sqlite

# 屏蔽所有音频文件
*.mp3
*.flac
*.wav
*.ogg
*.m4a

# 屏蔽所有封面和图片资源
*.jpg
*.jpeg
*.png
*.webp
*.gif

# ==========================================
# ☕ 后端屏蔽 (Spring Boot / Java / Maven)
# ==========================================
target/
*.jar
*.war
.mvn/wrapper/maven-wrapper.jar

# ==========================================
# 💻 前端屏蔽 (Node.js / Vue / Nuxt)
# ==========================================
node_modules/
dist/
.nuxt/
.output/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ==========================================
# 🛠️ IDE 与系统环境屏蔽 (Mac/Windows/IDEA)
# ==========================================
.idea/
*.iml
*.iws
*.ipr
.vscode/
